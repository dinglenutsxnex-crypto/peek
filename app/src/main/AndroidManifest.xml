<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed to write to public Downloads on Android 8/9 (API 26-28).
         On Android 10+ (API 29+) MediaStore.Downloads requires no permission. -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".PeekApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Peek.NoActionBar"
        android:largeHeap="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Peek.NoActionBar"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AnalysisActivity"
            android:exported="false"
            android:theme="@style/Theme.Peek.NoActionBar"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".DisassemblyActivity"
            android:exported="false"
            android:theme="@style/Theme.Peek.NoActionBar"
            android:parentActivityName=".AnalysisActivity" />

        <activity
            android:name=".XrefActivity"
            android:exported="false"
            android:theme="@style/Theme.Peek.NoActionBar"
            android:parentActivityName=".AnalysisActivity" />

        <activity
            android:name=".SymbolsActivity"
            android:exported="false"
            android:theme="@style/Theme.Peek.NoActionBar"
            android:parentActivityName=".FunctionListActivity" />

        <activity
            android:name=".FunctionListActivity"
            android:exported="false"
            android:theme="@style/Theme.Peek.NoActionBar"
            android:parentActivityName=".AnalysisActivity" />

    </application>

</manifest>
