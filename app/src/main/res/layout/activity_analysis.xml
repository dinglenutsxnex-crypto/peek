<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_dark">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="37dp"
            android:minHeight="37dp"
            android:background="@color/bg_elevated"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_secondary"
            app:navigationIconTint="@color/text_primary"
            app:contentInsetStart="8dp"
            app:contentInsetStartWithNavigation="8dp"
            app:titleTextAppearance="@style/PeekToolbarTitle" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Left: function panel -->
            <LinearLayout
                android:id="@+id/leftPanel"
                android:layout_width="160dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/bg_surface">

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:hint="search…"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@color/bg_elevated"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1"
                    android:imeOptions="actionSearch" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFunctions"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="never"
                        android:clipToPadding="false"
                        android:paddingTop="12dp"
                        android:paddingBottom="32dp"
                        android:scrollbars="vertical"
                        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                        android:scrollbarSize="2dp"
                        android:fadeScrollbars="false" />

                    <View
                        android:id="@+id/scrollHint"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/scroll_hint_gradient"
                        android:importantForAccessibility="no" />

                </FrameLayout>

            </LinearLayout>

            <!-- Draggable divider -->
            <View
                android:id="@+id/dividerHandle"
                android:layout_width="8dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- Right: tabs + content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@color/bg_elevated"
                    app:tabTextColor="@color/text_secondary"
                    app:tabSelectedTextColor="@color/text_primary"
                    app:tabIndicatorColor="@color/accent_bright"
                    app:tabIndicatorHeight="2dp"
                    app:tabTextAppearance="@style/TabTextSmall"
                    app:tabMode="fixed"
                    app:tabGravity="fill"
                    app:tabRippleColor="@android:color/transparent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingTop="12dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Floating download dropdown — same style as view options -->
    <LinearLayout
        android:id="@+id/downloadContainer"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_gravity="top|end"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="40dp"
        android:background="@color/bg_elevated"
        android:elevation="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@color/bg_elevated"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:text="DOWNLOAD"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/dlHex"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:text="Download Hex"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/dlAsm"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:text="Download Disassembly"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/dlPseudocode"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:text="Download Pseudocode"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Floating view-options dropdown -->
    <LinearLayout
        android:id="@+id/viewOptionsContainer"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_gravity="top|end"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="4dp"
        android:background="@color/bg_elevated"
        android:elevation="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@color/bg_elevated"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:text="VIEW OPTIONS"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="monospace" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvViewOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</FrameLayout>
