<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Full-width header: spans the whole screen, sits above the split. -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:minHeight="32dp"
            android:background="@color/bg_elevated"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_secondary"
            app:navigationIconTint="@color/text_primary"
            app:contentInsetStart="8dp"
            app:contentInsetStartWithNavigation="8dp"
            app:titleTextAppearance="@style/PeekToolbarTitle" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <!-- Below the header: left function panel + draggable divider + content. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Left: function panel -->
            <LinearLayout
                android:id="@+id/leftPanel"
                android:layout_width="160dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/bg_surface">

                <!-- View / Download action button row (5dp top padding pushes them down) -->
                <LinearLayout
                    android:id="@+id/actionButtonRow"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:orientation="horizontal"
                    android:paddingTop="5dp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <ImageButton
                        android:id="@+id/btnViewOptions"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:src="@drawable/ic_view_options"
                        android:background="?attr/selectableItemBackground"
                        android:tint="@color/text_secondary"
                        android:contentDescription="View options"
                        android:scaleType="fitCenter"
                        android:padding="3dp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/divider" />

                    <ImageButton
                        android:id="@+id/btnDownload"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:src="@drawable/ic_download"
                        android:background="?attr/selectableItemBackground"
                        android:tint="@color/text_secondary"
                        android:contentDescription="Download"
                        android:scaleType="fitCenter"
                        android:padding="3dp" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- Expandable View Options panel (drops inline below buttons) -->
                <LinearLayout
                    android:id="@+id/viewOptionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="26dp"
                        android:background="@color/bg_elevated"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:text="VIEW OPTIONS"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="monospace" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvViewOptions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />
                </LinearLayout>

                <!-- Expandable Download Options panel (drops inline below buttons) -->
                <LinearLayout
                    android:id="@+id/downloadOptionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="26dp"
                        android:background="@color/bg_elevated"
                        android:gravity="center_vertical"
                        android:paddingStart="10dp"
                        android:text="DOWNLOAD AS"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tvDlHex"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:drawablePadding="8dp"
                        android:text="Hex dump"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvDlAsm"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:text="Disassembly"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tvDlPseudocode"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:text="Pseudocode"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider" />
                </LinearLayout>

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:hint="search…"
                    android:textSize="11sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:background="@color/bg_elevated"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1"
                    android:imeOptions="actionSearch" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <!-- Function list wrapped in FrameLayout to layer the scroll hint gradient -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvFunctions"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="never"
                        android:clipToPadding="false"
                        android:paddingTop="8dp"
                        android:paddingBottom="36dp"
                        android:scrollbars="vertical"
                        android:scrollbarThumbVertical="@drawable/scrollbar_thumb"
                        android:scrollbarSize="2dp"
                        android:fadeScrollbars="false" />

                    <!-- Bottom-fade gradient: visible when list has more items below -->
                    <View
                        android:id="@+id/scrollHintGradient"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_gravity="bottom"
                        android:background="@drawable/scroll_hint_gradient"
                        android:clickable="false"
                        android:focusable="false"
                        android:visibility="gone" />

                </FrameLayout>

            </LinearLayout>

            <!-- Draggable divider: 8dp solid bar -->
            <View
                android:id="@+id/dividerHandle"
                android:layout_width="8dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- Right: tabs + content -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout"
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:background="@color/bg_elevated"
                    app:tabTextColor="@color/text_secondary"
                    app:tabSelectedTextColor="@color/text_primary"
                    app:tabIndicatorColor="@color/accent_bright"
                    app:tabIndicatorHeight="2dp"
                    app:tabTextAppearance="@style/TabTextSmall"
                    app:tabMode="fixed"
                    app:tabGravity="fill"
                    app:tabRippleColor="@android:color/transparent" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPager"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingTop="12dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Watermark: Peek eye icon, monochromatic, barely-visible behind all UI.
         Placed last so it renders above the solid bg_dark but at 5% opacity it
         reads visually as a background texture — non-interactive. -->
    <ImageView
        android:id="@+id/ivWatermark"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_peek_logo"
        android:tint="#AAAACC"
        android:alpha="0.05"
        android:scaleType="fitCenter"
        android:clickable="false"
        android:focusable="false"
        android:importantForAccessibility="no" />

</FrameLayout>
