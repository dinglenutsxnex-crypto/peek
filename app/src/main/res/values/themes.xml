<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Peek" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/bg_surface</item>
        <item name="colorPrimaryVariant">@color/bg_elevated</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="actionBarStyle">@style/PeekActionBar</item>
    </style>

    <style name="PeekActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/bg_surface</item>
        <item name="titleTextStyle">@style/PeekActionBarTitle</item>
    </style>

    <style name="PeekActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">monospace</item>
    </style>
</resources>
